import numpy as np
from parameters import seed_ran, p0, p2
from kinematic import *

def simulation():
    
    # Generation of stochastic spacing data based on geaar-drive kinematics
    rng = np.random.default_rng(seed_ran)
    
    nominal_m = spacing()
    
    p1 = 1.0-p0-p2
    multipliers = rng.choice([1.0, 2.0, 0.5], size=N, p=[p1, p0, p2])
    
    noise = rng.normal(0, nominal_m*noise_frac, N)
    spacings = (nominal_m*multipliers+noise)*100
    return spacings
